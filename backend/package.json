{
  "name": "wled-buzzer-backend",
  "version": "0.0.1",
  "description": "Backend server for WLED Quiz buzzer system",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "package": "pkg server.js --targets node18-win-x64 --output ../dist/wled-buzzer.exe"
  },
  "dependencies": {
    "aedes": "^0.51.2",
    "axios": "^0.27.2",
    "express": "^4.22.1",
    "mqtt": "^5.3.0",
    "net": "^1.0.2",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "pkg": "^5.8.1"
  },
  "pkg": {
    "assets": [],
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "../dist"
  }
}
